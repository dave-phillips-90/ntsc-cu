{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debug: Module",
            "type": "debugpy",
            "request": "launch",
            "module": "ntsc-cu",
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            }
        },
        {
            "name": "Python Debug: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            }
        }
    ]
}